
<div class="flex-1 flex flex-col justify-center items-center p-8 md:p-16 lg:p-24 bg-base-200">
  <div class="w-full max-w-sm space-y-8">

    <div class="space-y-2">
      <span class="text-xs font-semibold tracking-widest text-primary uppercase">Witaj z powrotem</span>
      <h2 class="text-3xl font-bold text-base-content tracking-tight">Ruszajmy w drogę</h2>
      <p class="text-sm text-base-content/60">Zaloguj się, aby zobaczyć swoje podróże.</p>
    </div>


    <div class="tabs tabs-boxed bg-base-100 p-1 border border-base-300">

      <%# ── Tab: Logowanie ── %>
      <input type="radio" name="auth_tabs" class="tab" aria-label="Logowanie" checked="checked"/>
      <div class="tab-content pt-6 space-y-5">
        <%= form_with url: session_path, method: :post do |f| %>
          <div class="form-control w-full">
            <%= f.label :email_address, "Adres e-mail", class: "label pb-1" %>
            <%= f.email_field :email_address,
                  required: true,
                  autofocus: true,
                  autocomplete: "username",
                  placeholder: "Adres e-mail",
                  value: params[:email_address],
                  class: "input input-bordered w-full" %>
          </div>

          <div class="form-control w-full">
            <%= f.label :password, "Hasło", class: "label pb-1" %>
            <%= f.password_field :password,
                  required: true,
                  autocomplete: "current-password",
                  placeholder: "••••••••",
                  maxlength: 72,
                  class: "input input-bordered w-full" %>
          </div>

          <%= f.submit "Zaloguj się", class: "btn btn-primary w-full mt-2" %>
        <% end %>
      </div>

    </div>
    <div class="flex items-center justify-between">
      <button class="link link-primary" onclick="registration_modal.showModal()">Zarejestruj się</button>
      <dialog id="registration_modal" class="modal modal-bottom sm:modal-middle">
        <div class="modal-box">
          <form method="dialog">
          <button class="btn btn-sm btn-circle btn-ghost absolute right-2 top-2">✕</button>
          </form>
          <%= turbo_frame_tag "registration_modal", src: new_registration_path, loading: :lazy do %>
          <span class="loading loading-dots loading-md"></span>
          <% end %>
      </div>
      </dialog>
      <%= link_to "Nie pamiętasz hasła?", new_password_path, class: "link link-primary" %>
    </div>

  </div>
</div>